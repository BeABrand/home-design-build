VITE_ENQUIRY_ENDPOINT=/.netlify/functions/send-enquiry

SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@buildplanandrafting.com.au
SMTP_PASS=

ENQUIRY_TO_EMAIL=info@buildplanandrafting.com.au
ENQUIRY_FROM_EMAIL=info@buildplanandrafting.com.au
ENQUIRY_FROM_NAME=Build Plan Drafting Website

# Optional. Defaults to ./public/storage when omitted.
ENQUIRY_PUBLIC_STORAGE_DIR=public/storage

# Optional. When omitted, the function will infer https://<current-host>/storage/<filename>
# only if uploads are being written into ./public/storage on a runtime that actually serves it.
ENQUIRY_PUBLIC_STORAGE_BASE_URL=https://buildplandrafting.com.au/storage
