# Zoho SMTP configuration
#
# CRITICAL — regional SMTP host must match your Zoho data center:
#   US:        smtp.zoho.com         (free) | smtppro.zoho.com         (Workspace/paid)
#   Europe:    smtp.zoho.eu          (free) | smtppro.zoho.eu          (Workspace/paid)
#   Australia: smtp.zoho.com.au      (free) | smtppro.zoho.com.au      (Workspace/paid)
#   India:     smtp.zoho.in          (free) | smtppro.zoho.in          (Workspace/paid)
#   China:     smtp.zoho.com.cn      (free) | smtppro.zoho.com.cn      (Workspace/paid)
# Confirm region by logging into Zoho web mail and reading the URL: mail.zoho.<region>
SMTP_HOST=smtppro.zoho.com.au
SMTP_PORT=465
SMTP_SECURE=true

# SMTP_USER must be the full Zoho mailbox address.
SMTP_USER=info@buildplandrafting.com.au

# SMTP_PASS MUST be an App-Specific Password, NOT your Zoho login password.
# Generate one at: https://accounts.zoho.com.au/home#security/app_passwords
# (substitute your region tld). 2FA does not need to be enabled for app passwords
# to be required by Zoho's "untrusted device" policy.
SMTP_PASS=

# Recipient + sender. ENQUIRY_FROM_EMAIL must match SMTP_USER or a verified
# Zoho alias on that mailbox — otherwise Zoho rejects the send (5xx).
ENQUIRY_TO_EMAIL=info@buildplandrafting.com.au
ENQUIRY_FROM_EMAIL=info@buildplandrafting.com.au
ENQUIRY_FROM_NAME=Build Plan Drafting Website

# Optional: where to write uploaded files. Defaults to ./public/storage.
ENQUIRY_PUBLIC_STORAGE_DIR=public/storage

# Optional: public base URL for uploaded files. Note the domain spelling —
# it MUST exactly match the live site domain. The 2026-05-15 incident was
# caused by a typo (buildplandrafting vs buildplanandrafting).
ENQUIRY_PUBLIC_STORAGE_BASE_URL=https://buildplanandrafting.com.au/storage

# Optional: override the function endpoint for the frontend fetch().
VITE_ENQUIRY_ENDPOINT=/.netlify/functions/send-enquiry
